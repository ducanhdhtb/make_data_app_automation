<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="smoke" verbose="1">
  <!-- Run tests tagged with group 'smoke' (also typically tagged as 'regression'). -->
  <test name="smoke">
    <groups>
      <run>
        <include name="smoke"/>
      </run>
    </groups>
    <packages>
      <package name="com.nearmatch.tests.api"/>
      <package name="com.nearmatch.tests.ui"/>
    </packages>
  </test>
</suite>
